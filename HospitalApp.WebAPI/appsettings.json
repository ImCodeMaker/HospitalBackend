{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BusinessInfo": {
    "Name": "Lova Salud",
    "Description": "A clinical site",
    "Email": "support@lovasalud.com"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "HangfireDashboard": {
    "User": "",
    "Password": ""
  },
  "SeedAdmin": {
    "Enabled": false,
    "Email": "",
    "Password": ""
  },
  "ExternalIntegrations": {
    "AllowStubs": false
  },
  "FileStorage": {
    "AllowLocal": false
  },
  "MalwareScanner": {
    "Provider": "",
    "ClamAv": {
      "Host": "localhost",
      "Port": 3310
    }
  },
  "PiiProtection": {
    "Key": ""
  },
  "Audit": {
    "RetentionYears": 7
  },
  "Idempotency": {
    "Enabled": true,
    "HeaderName": "Idempotency-Key",
    "RetentionHours": 24,
    "MaxKeyLength": 160,
    "MaxResponseBytes": 1048576
  },
  "SeedMockData": false,
  "AdminIpAllowlist": {
    "Enabled": true,
    "AllowedCidrs": [ "127.0.0.1/32", "::1/128" ],
    "ProtectedPaths": [ "/api/v1/audit", "/api/v1/users", "/api/v1/ncfsequences", "/api/v1/controlledsubstancelog", "/hangfire" ]
  },
  "JwtSettings": {
    "Key": "",
    "Issuer": "lova-salud-api",
    "Audience": "lova-salud-client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Redis": {
    "ConnectionString": ""
  },
  "TwilioSettings": {
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  }
}
